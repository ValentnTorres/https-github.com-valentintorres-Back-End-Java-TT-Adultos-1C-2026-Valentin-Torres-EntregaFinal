{
  "info": {
    "name": "Gestor de Tareas y Proyectos - API",
    "description": "Coleccion de Postman para probar la API REST del proyecto final (Spring Boot + MySQL). Ver el README del repo para mas contexto.\n\nComo usarla:\n1) Correr \"Auth > Login\" (o \"Usuarios > Registrar usuario\" primero si todavia no existe la cuenta).\n2) Copiar el \"token\" de la respuesta y pegarlo en la variable de coleccion \"token\" (Edit > Variables, o el icono del ojo arriba a la derecha).\n3) A partir de ahi, todos los demas requests ya usan ese token solos (Authorization: Bearer {{token}}).\n\nLa variable \"base_url\" ya viene apuntando al deploy en Render. Para probar contra tu backend local, cambiala a http://localhost:8080/api.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://java-entregafinal-valentintorres.onrender.com/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"valen@example.com\",\n  \"password\": \"secreto123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
            "description": "Publico (no necesita token). Devuelve el JWT: copialo a la variable de coleccion \"token\"."
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Valentin Torres\",\n  \"email\": \"valen@example.com\",\n  \"password\": \"secreto123\"\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] },
            "description": "Publico (no necesita token). password minimo 6 caracteres."
          }
        },
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/usuarios", "host": ["{{base_url}}"], "path": ["usuarios"] }
          }
        },
        {
          "name": "Editar usuario",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Valentin Torres\",\n  \"email\": \"valen@example.com\"\n}"
            },
            "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] }
          }
        },
        {
          "name": "Borrar usuario",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/usuarios/1", "host": ["{{base_url}}"], "path": ["usuarios", "1"] },
            "description": "Falla con 400 si el usuario todavia esta asignado a alguna tarea."
          }
        }
      ]
    },
    {
      "name": "Proyectos",
      "item": [
        {
          "name": "Crear proyecto",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Proyecto Final Java\",\n  \"descripcion\": \"TP de Talento Tech\"\n}"
            },
            "url": { "raw": "{{base_url}}/proyectos", "host": ["{{base_url}}"], "path": ["proyectos"] }
          }
        },
        {
          "name": "Listar proyectos",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/proyectos", "host": ["{{base_url}}"], "path": ["proyectos"] }
          }
        },
        {
          "name": "Editar proyecto",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Proyecto Final Java (editado)\",\n  \"descripcion\": \"TP de Talento Tech\"\n}"
            },
            "url": { "raw": "{{base_url}}/proyectos/1", "host": ["{{base_url}}"], "path": ["proyectos", "1"] }
          }
        },
        {
          "name": "Borrar proyecto",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/proyectos/1", "host": ["{{base_url}}"], "path": ["proyectos", "1"] },
            "description": "Borra en cascada todas las tareas de ese proyecto."
          }
        }
      ]
    },
    {
      "name": "Columnas",
      "item": [
        {
          "name": "Crear columna",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"En revisión\",\n  \"esFinal\": false\n}"
            },
            "url": { "raw": "{{base_url}}/columnas", "host": ["{{base_url}}"], "path": ["columnas"] }
          }
        },
        {
          "name": "Listar columnas",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/columnas", "host": ["{{base_url}}"], "path": ["columnas"] }
          }
        },
        {
          "name": "Editar columna",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"En revisión\",\n  \"esFinal\": true\n}"
            },
            "url": { "raw": "{{base_url}}/columnas/1", "host": ["{{base_url}}"], "path": ["columnas", "1"] }
          }
        },
        {
          "name": "Borrar columna",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/columnas/1", "host": ["{{base_url}}"], "path": ["columnas", "1"] },
            "description": "Falla con 400 si la columna todavia tiene tareas."
          }
        },
        {
          "name": "Reordenar columnas",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "[2, 1, 3]"
            },
            "url": { "raw": "{{base_url}}/columnas/reordenar", "host": ["{{base_url}}"], "path": ["columnas", "reordenar"] },
            "description": "Lista de ids de columna en el orden nuevo (de izquierda a derecha)."
          }
        }
      ]
    },
    {
      "name": "Tareas",
      "item": [
        {
          "name": "Crear tarea",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Modelar entidades\",\n  \"descripcion\": \"JPA + relaciones\",\n  \"fechaLimite\": \"2026-12-31\",\n  \"columna\": { \"id\": 1 },\n  \"proyecto\": { \"id\": 1 }\n}"
            },
            "url": { "raw": "{{base_url}}/tareas", "host": ["{{base_url}}"], "path": ["tareas"] }
          }
        },
        {
          "name": "Listar tareas",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/tareas", "host": ["{{base_url}}"], "path": ["tareas"] }
          }
        },
        {
          "name": "Editar tarea",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Modelar entidades (editado)\",\n  \"descripcion\": \"JPA + relaciones\",\n  \"fechaLimite\": \"2026-12-31\",\n  \"columna\": { \"id\": 2 },\n  \"proyecto\": { \"id\": 1 }\n}"
            },
            "url": { "raw": "{{base_url}}/tareas/1", "host": ["{{base_url}}"], "path": ["tareas", "1"] }
          }
        },
        {
          "name": "Borrar tarea",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": { "raw": "{{base_url}}/tareas/1", "host": ["{{base_url}}"], "path": ["tareas", "1"] }
          }
        },
        {
          "name": "Asignar usuario a tarea",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{base_url}}/tareas/1/usuarios/1",
              "host": ["{{base_url}}"],
              "path": ["tareas", "1", "usuarios", "1"]
            },
            "description": "Falla con 400 si el usuario ya estaba asignado, o si la tarea esta en una columna marcada como final."
          }
        },
        {
          "name": "Quitar usuario de tarea",
          "request": {
            "method": "DELETE",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "url": {
              "raw": "{{base_url}}/tareas/1/usuarios/1",
              "host": ["{{base_url}}"],
              "path": ["tareas", "1", "usuarios", "1"]
            }
          }
        }
      ]
    }
  ]
}
